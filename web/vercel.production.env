# Tratto Contábil — variáveis para Vercel Production
#
# 1. cp vercel.production.env .env.vercel
# 2. Preencha os valores REPLACE_* (Supabase + Meta + seu e-mail)
# 3. Vercel → trattocontabil → Settings → Environment Variables → Import .env
#    → selecione .env.vercel → Environment: Production → Save
# 4. Redeploy: npx vercel --prod
#
# Não commite .env.vercel (contém secrets).

# --- Supabase Cloud (Dashboard → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=REPLACE_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_SUPABASE_SERVICE_ROLE_KEY

# --- App ---
DEFAULT_ESCRITORIO_SLUG=e2-piloto
PLATFORM_ADMIN_EMAILS=REPLACE_SEU_EMAIL
REGUA_MODE=dry_run

# --- Secrets (já gerados — use o mesmo WHATSAPP_VERIFY_TOKEN na Meta) ---
WORKER_SECRET=9a3a762c825f9a31d9a0727cdae43bd434eeb1c0f9ada54dcd7a192b3ae6d97e
INBOUND_EMAIL_SECRET=a948225e9e92fb9961e6fab0a054fb773c60ae7cbcb0cdf51abaf65877257b5b
WHATSAPP_VERIFY_TOKEN=bef5ef1dec735331c4b9034751c2e5ffcdeca862f86610b9

# --- Meta WhatsApp (developers.facebook.com → seu app) ---
WHATSAPP_APP_SECRET=REPLACE_META_APP_SECRET
WHATSAPP_ACCESS_TOKEN=REPLACE_META_ACCESS_TOKEN
WHATSAPP_PHONE_NUMBER_ID=REPLACE_META_PHONE_NUMBER_ID

# --- PDF (opcional — deixe vazio se só OFX/WhatsApp por enquanto) ---
ANTHROPIC_API_KEY=
PDF_MODEL_PRIMARY=claude-sonnet-4-6
PDF_MODEL_FALLBACK=claude-opus-4-8

# CRON_SECRET — preenchido automaticamente pelo Vercel Cron após deploy
